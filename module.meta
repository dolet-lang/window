# Window Module Metadata
# Native Windows API bindings for window creation and management

[info]
name = window
version = 1.3.0
description = Native Windows API bindings — window creation, lifecycle, event buffers, framebuffer present, and client-space mouse readers. Self-contained: does NOT depend on any other Dolet package. Only place in the stack that declares Win32 externs.

[libs]
# No external libraries needed - uses Windows system DLLs

[dlls]
# No runtime DLLs to copy - uses Windows system DLLs (user32.dll, kernel32.dll)

[dependencies]
# None — window is self-contained.

# Platform-specific linking information
[link.windows]
system_libs = user32, gdi32, kernel32

[link.linux]
# Linux uses X11 for windowing
flags = -lX11 -lGL

[link.macos]
# macOS uses Cocoa framework
frameworks = Cocoa, Metal
